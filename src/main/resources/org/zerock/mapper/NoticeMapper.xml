<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.zerock.mapper.NoticeMapper">

    <!-- 전체 공지 목록 -->
    <select id="getList" resultType="org.zerock.domain.NoticeVO">
        SELECT * FROM notice ORDER BY reg_date DESC
    </select>

    <!-- 공지 단건 조회 -->
    <select id="read" resultType="org.zerock.domain.NoticeVO">
        SELECT * FROM notice WHERE notice_id = #{notice_id}
    </select>

    <!-- 공지 등록 -->
    <insert id="insert" parameterType="org.zerock.domain.NoticeVO">
        <selectKey keyProperty="notice_id" resultType="java.lang.Long" order="BEFORE">
            SELECT notice_seq.NEXTVAL FROM dual
        </selectKey>
        INSERT INTO notice (
            notice_id,
            title,
            content,
            writer,
            reg_date,
            view_count,
            important
        ) VALUES (
            #{notice_id},
            #{title},
            #{content},
            #{writer},
            SYSDATE,
            0,
            #{important}
            
        )
    </insert>

    <!-- 공지 수정 -->
    <update id="update" parameterType="org.zerock.domain.NoticeVO">
        UPDATE notice
        SET
            title = #{title},
            content = #{content},
            writer = #{writer},
            update_date = SYSDATE,
        	important = #{important}
        WHERE notice_id = #{notice_id}
    </update>

    <!-- 공지 삭제 -->
    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM notice WHERE notice_id = #{notice_id}
    </delete>
    
    <!-- 공지 조회수 증가 -->
    <update id="updateViewCount" parameterType="long">
	    UPDATE notice
	    SET view_count = view_count + 1
	    WHERE notice_id = #{notice_id}
	</update>

</mapper>